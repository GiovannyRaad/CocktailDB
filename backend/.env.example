# Backend environment template
# Copy to .env and fill values.

# Database mode: sqlite or postgres
DB_MODE=sqlite

# SQLite settings
SQLITE_DATABASE_URL=sqlite:///./cocktail.db

# Postgres settings (used when DB_MODE=postgres)
# Option 1: full URL (takes priority)
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Option 2: separate fields
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD
DB_HOST=db.YOUR_PROJECT_REF.supabase.co
DB_PORT=5432
DB_NAME=postgres

# Legacy lowercase aliases supported by current config
# user=postgres
# password=YOUR_PASSWORD
# host=db.YOUR_PROJECT_REF.supabase.co
# port=5432
# dbname=postgres

# Upload/storage settings
UPLOADS_DIR=./uploads
BACKEND_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Auth settings
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
